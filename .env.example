# Neon PostgreSQL — pooled connection string (app runtime)
DATABASE_URL=postgresql://<user>:<password>@<host>-pooler.<region>.aws.neon.tech/<db>?sslmode=require

# Neon PostgreSQL — direct connection string (drizzle-kit migrations only)
DATABASE_URL_UNPOOLED=postgresql://<user>:<password>@<host>.<region>.aws.neon.tech/<db>?sslmode=require

# Vercel Blob — read/write token (required for photo uploads)
# Set this in Vercel project settings → Environment Variables → Production.
# Vercel sets it automatically if you attach a Blob store via the Storage tab.
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_...

# Vision model — set to false to call the real Claude vision API
MOCK_VISION=true

# Anthropic API key — required when MOCK_VISION=false
ANTHROPIC_API_KEY=sk-ant-...

# Auth — secret for signing the mock session cookie
AUTH_SECRET=change-me-to-a-random-string
