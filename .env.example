# Neon PostgreSQL — pooled connection string (app runtime)
DATABASE_URL=

# Neon PostgreSQL — direct connection string (drizzle-kit migrations only)
DATABASE_URL_UNPOOLED=

# Vercel Blob — read/write token (photo uploads)
BLOB_READ_WRITE_TOKEN=

# Set to "true" to use the mock vision path (default); set to "false" to call the real vision model
MOCK_VISION=true

# Secret used to sign the mock session cookie
AUTH_SECRET=

# Anthropic API key — only required when MOCK_VISION=false
ANTHROPIC_API_KEY=
